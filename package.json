{
  "name": "ariadne",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,worker \"next dev\" \"tsx watch worker/index.ts\"",
    "dev:web": "next dev",
    "dev:worker": "tsx watch worker/index.ts",
    "build": "next build",
    "start": "concurrently -k -n web,worker \"next start\" \"tsx worker/index.ts\"",
    "worker": "tsx worker/index.ts",
    "lint": "eslint",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:smoke": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@playwright/mcp": "^0.0.70",
    "@sentry/nextjs": "^10.50.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "lucide-react": "^1.9.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "pg-boss": "^12.16.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
